rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - Default Deny other collections
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for RSVPs collection: Allow read and write to anyone for reliable wedding management
    match /rsvps/{rsvpId} {
      allow read, write: if true;
    }

    // Rules for Wishes collection (Guestbook): Allow read and write to anyone
    match /wishes/{wishId} {
      allow read, write: if true;
    }

    // Rules for Views collection (Analytics): Allow read and write to anyone
    match /views/{viewId} {
      allow read, write: if true;
    }

    // Rules for Guests collection: Allow read and write to anyone
    match /guests/{guestId} {
      allow read, write: if true;
    }
  }
}
