{
  "entities": {
    "RSVP": {
      "title": "RSVP",
      "description": "Thông tin khách mời xác nhận tham dự đám cưới",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Tên khách mời"
        },
        "attendance": {
          "type": "string",
          "description": "Trạng thái tham dự: 'yes' (Tham dự), 'no' (Không tham dự), 'maybe' (Có thể)"
        },
        "guestCount": {
          "type": "integer",
          "description": "Số lượng người đi cùng"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Thời gian gửi xác nhận"
        }
      },
      "required": [
        "name",
        "attendance",
        "guestCount"
      ]
    },
    "Wish": {
      "title": "Wish",
      "description": "Lời chúc của khách mời gửi tới cặp đôi",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Tên người gửi lời chúc"
        },
        "wishes": {
          "type": "string",
          "description": "Lời chúc gửi tới cô dâu chú rể"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Thời gian gửi lời chúc"
        }
      },
      "required": [
        "name",
        "wishes"
      ]
    },
    "View": {
      "title": "View",
      "description": "Lịch sử khách mời bấm mở thiệp cưới",
      "type": "object",
      "properties": {
        "guestName": {
          "type": "string",
          "description": "Tên khách mời"
        },
        "userAgent": {
          "type": "string",
          "description": "Trình duyệt hoặc thiết bị"
        },
        "clickedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Thời gian click mở"
        }
      },
      "required": [
        "clickedAt"
      ]
    },
    "Guest": {
      "title": "Guest",
      "description": "Thông tin và thống kê mở thiệp của từng khách mời",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Tên khách mời"
        },
        "viewsCount": {
          "type": "integer",
          "description": "Tổng số lượt click mở thiệp cưới"
        },
        "lastViewedAt": {
          "type": "string",
          "description": "Thời gian xem gần nhất"
        },
        "views": {
          "type": "array",
          "description": "Danh sách chi tiết các lần bấm xem"
        }
      },
      "required": [
        "name",
        "viewsCount"
      ]
    }
  },
  "firestore": {
    "rsvps/{rsvpId}": {
      "schema": "RSVP",
      "description": "Danh sách khách xác nhận tham dự"
    },
    "wishes/{wishId}": {
      "schema": "Wish",
      "description": "Danh sách lời chúc của khách mời"
    },
    "views/{viewId}": {
      "schema": "View",
      "description": "Lịch sử khách mời mở thiệp"
    },
    "guests/{guestId}": {
      "schema": "Guest",
      "description": "Danh sách khách mời chính thức để gửi thiệp"
    }
  }
}
